# ============================================
# AZUR ERP · Environment variables
# Copy to .env.local and fill in real values
# ============================================

# --- App ---
NEXT_PUBLIC_APP_NAME="AZUR Constructora e Inmobiliaria"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ENV="development"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJI..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJI..."

# Used only by scripts/run-migrations.ts (Supabase Management API)
SUPABASE_PROJECT_REF="your-project-ref"
SUPABASE_ACCESS_TOKEN="sbp_..."
SUPABASE_DB_PASSWORD=""

# --- Web Push (VAPID, generate with: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:luigi@promptive.pe"

# --- Resend (transactional email) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AZUR ERP <no-reply@azur.dev>"

# --- Dev quick-access password (used to seed dev users) ---
DEV_USERS_PASSWORD="azur2026"
